{
    "name": "workflow",
    "private": true,
    "version": "0.0.1",
    "engines": {
        "node": ">=22.0.0 <23 || >=24.0.0 <25 || >=26.0.0 <27"
    },
    "main": "src/workflow.js",
    "bin": {
        "workflow": "src/workflow.js"
    },
    "scripts": {
        "postinstall": "run-script-os",
        "postinstall:win32": "if not exist .env copy .env.example .env else echo \"[INFO]: '.env' already exists!\"",
        "postinstall:darwin:linux": "[ ! -f .env ] && cp .env.example .env || echo \"[INFO]: '.env' already exists!\"",
        "workflow": "tsx src/workflow.ts"
    },
    "type": "module",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@swc/core": "^1.15.43",
        "@swc/helpers": "^0.5.23",
        "@types/debug": "^4.1.13",
        "@types/node": "^26.0.1",
        "eslint": "^10.5.0",
        "globals": "^17.6.0",
        "run-script-os": "^1.1.6",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3"
    },
    "dependencies": {
        "@srhenry/type-utils": "^0.8.3",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "debug": "^4.4.3",
        "dotenv": "^17.4.2",
        "tsx": "^4.22.3"
    }
}
